# Entorno general
NODE_ENV=development

# Backend / API
PORT=3001

# Opción A: PostgreSQL local con Docker Compose
DATABASE_URL=postgres://volleyflow:volleyflow@localhost:5432/volleyflow
MIGRATION_DATABASE_URL=postgres://volleyflow:volleyflow@localhost:5432/volleyflow
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Opción B: Neon/PostgreSQL remoto
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
# MIGRATION_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

DATABASE_POOL_MAX=5
JWT_SECRET=change-me-in-local-development
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=true

# Seed inicial de administrador
SEED_ADMIN_EMAIL=admin@volleyflow.local
SEED_ADMIN_NAME=Admin VolleyFlow
SEED_ADMIN_PASSWORD=Cambiar123!

# Frontend / Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api
